{
  "name": "evidrift",
  "version": "0.3.1",
  "mcpName": "io.github.bm1016bm-svg/evidrift",
  "description": "Catch TypeScript API and OpenAPI contract drift in AI-generated code. Local-first CLI and MCP server that revalidates assumptions in CI.",
  "keywords": [
    "ai",
    "ai-coding-agents",
    "ai-generated-code",
    "api-drift",
    "ci",
    "cli",
    "contract-testing",
    "dependency-contracts",
    "developer-tools",
    "evidence-lockfile",
    "github-actions",
    "json-pointer",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "openapi-drift",
    "provenance",
    "openapi",
    "static-analysis",
    "typescript",
    "typescript-mcp"
  ],
  "homepage": "https://bm1016bm-svg.github.io/evidrift/",
  "bugs": {
    "url": "https://github.com/bm1016bm-svg/evidrift/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bm1016bm-svg/evidrift.git"
  },
  "license": "MPL-2.0",
  "type": "module",
  "bin": {
    "evidrift": "dist/src/cli.js",
    "evidrift-mcp": "dist/src/mcp.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "main": "./dist/src/index.js",
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "examples/signature-drift/app",
    "examples/signature-drift/fixture-package"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "node dist/src/cli.js check",
    "demo": "npm run build && node dist/src/cli.js demo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src tests --max-warnings 0",
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run verify",
    "prepack": "npm run build",
    "release:check": "node scripts/verify-release.mjs",
    "smoke": "node dist/tests/smoke.js",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\" && npm run smoke",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "uat": "npm run build && node --test dist/tests/uat.test.js && npm run smoke",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chalk": "5.6.2",
    "ora": "9.4.1",
    "typescript": "5.9.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript-eslint": "8.64.0"
  }
}
